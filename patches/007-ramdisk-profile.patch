# PATCH: 007-ramdisk-profile
# PURPOSE: At startup, automatically create a RAM-backed filesystem, place the
#          Firefox profile on it, and destroy it on exit. No launch script needed.
#          The binary is self-contained — `./zerofox` just works.
#
# ── OVERVIEW ─────────────────────────────────────────────────────────────────
#
# Firefox's startup sequence in XRE_main() (toolkit/xre/nsAppRunner.cpp):
#   1. Parses command line
#   2. Selects/creates a profile via nsToolkitProfileService
#   3. Locks the profile directory
#   4. Starts the app
#
# We hook in between steps 1 and 2 to:
#   a. Create a RAM disk (platform-specific)
#   b. Create a profile directory on it
#   c. Write the embedded user.js into it
#   d. Force Firefox to use that directory as its profile
#   e. Register a shutdown observer to tear down the RAM disk on exit
#
# ── PART 1: New file — zerofox RAM disk module ────────────────────────────────
#
# Create: toolkit/xre/ZeroFoxRamDisk.h
# Create: toolkit/xre/ZeroFoxRamDisk.cpp
#
# Interface:
#   namespace zerofox {
#     // Creates RAM disk, writes profile, returns profile path.
#     // Returns empty string on failure.
#     nsString SetupRamProfile();
#
#     // Tears down the RAM disk. Called at shutdown.
#     void TeardownRamProfile();
#   }
#
