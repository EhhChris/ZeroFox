# ── PART 3: Hook into XRE_main ───────────────────────────────────────────────
#
# File: toolkit/xre/nsAppRunner.cpp
#
# Find: XRE_main() — the main entry point called from nsBrowserApp.cpp
# After argument parsing but before profile selection, add:
#
#   #include "ZeroFoxRamDisk.h"
