# ── PART 2: Embed user.js as a string constant ────────────────────────────────
#
# Rather than reading user.js from disk at runtime (which would require it to
# exist next to the binary), embed its content directly in the binary.
#
# In ZeroFoxRamDisk.cpp:
#
#   static const char kUserJs[] =
#     // Paste the full content of config/user.js here as a raw string literal:
#     R"USERJS(
#     user_pref("browser.cache.disk.enable", false);
#     user_pref("browser.privatebrowsing.autostart", true);
#     // ... all other prefs from config/user.js ...
#     )USERJS";
