#   ar.AddFlag("-profile");
#   ar.AddFlag(NS_ConvertUTF16toUTF8(ramProfilePath).get());
#
# The `ar` object is the parsed argument list. The exact API depends on the
# XRE_main signature in the version you're targeting — search for how
# existing code adds/overrides the "-profile" argument in nsAppRunner.cpp.
#
# ── PART 4: Shutdown observer ────────────────────────────────────────────────
#
# Register a shutdown observer in ZeroFoxRamDisk.cpp to call TeardownRamProfile()
# when Firefox quits cleanly. Also register an atexit() handler as a fallback
# for crash/kill scenarios.
