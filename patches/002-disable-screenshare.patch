# PATCH: 002-disable-screenshare
#
# Two enforcement layers:
#
# 1. JS/DOM layer -- MediaDevices::GetDisplayMedia (dom/media/MediaDevices.cpp)
#    Rejects navigator.mediaDevices.getDisplayMedia() unconditionally before
#    any permission prompt or constraint processing occurs. This is the primary
#    entry point for modern screen-capture requests from web content.
#
# 2. C++ core -- MediaManager::GetUserMedia (dom/media/MediaManager.cpp)
#    Replaces the pref-gated rejection for MediaSourceEnum::Screen,
#    ::Window, and ::Browser with an unconditional hard rejection. This covers
#    legacy getUserMedia({ video: { mediaSource: "screen" } }) calls and any
#    internal path (e.g. privileged chrome callers) that bypasses the DOM
#    layer above.
#
# Together these two hunks mean no screen-capture stream can be obtained
# regardless of pref state, caller privilege, or secure-context status.
#
# Not patched: the IPC boundary (PMediaTransport.ipdl / content->parent) is
# not a separate enforcement point in this codebase -- both content-process and
# parent-process calls funnel through MediaManager::GetUserMedia in the parent,
# so the hunk above is the single choke point.

--- a/dom/media/MediaDevices.cpp
+++ b/dom/media/MediaDevices.cpp
@@ -510,6 +510,11 @@
     return nullptr;
   }
   nsCOMPtr<nsPIDOMWindowInner> owner = do_QueryInterface(global);
+  // ZeroFox: getDisplayMedia() unconditionally rejected; screen capture is
+  // disabled by policy regardless of prefs or caller privilege.
+  p->MaybeRejectWithNotAllowedError(
+      "ZeroFox policy: screen capture is disabled");
+  return p.forget();
   /* If the relevant global object of this does not have transient activation,
    * return a promise rejected with a DOMException object whose name attribute
    * has the value InvalidStateError. */
--- a/dom/media/MediaManager.cpp
+++ b/dom/media/MediaManager.cpp
@@ -2945,19 +2945,12 @@
         [[fallthrough]];
       case MediaSourceEnum::Screen:
       case MediaSourceEnum::Window:
-        // Deny screensharing request if support is disabled, or
-        // the requesting document is not from a host on the whitelist.
-        if (!Preferences::GetBool(
-                ((videoType == MediaSourceEnum::Browser)
-                     ? "media.getusermedia.browser.enabled"
-                     : "media.getusermedia.screensharing.enabled"),
-                false) ||
-            (!privileged && !aWindow->IsSecureContext())) {
-          return StreamPromise::CreateAndReject(
-              MakeRefPtr<MediaMgrError>(MediaMgrError::Name::NotAllowedError),
-              __func__);
-        }
-        break;
+        // ZeroFox: screen/window/browser capture unconditionally rejected
+        // regardless of prefs or caller privilege.
+        return StreamPromise::CreateAndReject(
+            MakeRefPtr<MediaMgrError>(MediaMgrError::Name::NotAllowedError,
+                                      "ZeroFox policy: screen capture is disabled"),
+            __func__);
 
       case MediaSourceEnum::Microphone:
       case MediaSourceEnum::Other:
