# PATCH: 003-restrict-clipboard
#
# Blocks all clipboard and drag-to-copy access. Five entry points covered:
#
# 1. Clipboard::ReadHelper (dom/events/Clipboard.cpp)
#    Covers both Clipboard.read() and Clipboard.readText() -- both funnel
#    through this single method, so one block covers both.
#
# 2. Clipboard::Write (dom/events/Clipboard.cpp)
#    Covers Clipboard.write(). Clipboard.writeText() delegates to Write
#    internally, so this also blocks writeText().
#
# 3. Document::ExecCommand (dom/base/Document.cpp)
#    Blocks document.execCommand("cut"), execCommand("copy"), and
#    execCommand("paste") -- the legacy synchronous clipboard API still
#    widely used by web pages.
#
# 4. nsCopySupport::FireClipboardEvent (dom/base/nsCopySupport.cpp)
#    Blocks the user-level copy command (Ctrl+C, right-click Copy, address
#    bar Ctrl+C, etc.) for ALL content including browser chrome. This is
#    the path taken when the USER presses Ctrl+C -- it bypasses all JS
#    clipboard APIs and writes directly to the clipboard. Blocking here
#    prevents both the clipboard event dispatch AND the subsequent
#    EncodeDocumentWithContextAndPutToClipboard write.
#    Paste is deliberately NOT blocked so users can type into web forms.
#
# 5. nsBaseClipboard::SetData (widget/nsBaseClipboard.cpp)
#    The universal clipboard write funnel. Every path that writes to the OS
#    clipboard — whether from web content JS, the C++ editor, or chrome JS
#    via ClipboardHelper (e.g. the URL bar's doCommand()) — ultimately calls
#    this method. Replacing the SetNativeClipboardData call with NS_OK makes
#    all clipboard writes silently succeed without touching the OS pasteboard.
#    This is the backstop that catches anything FireClipboardEvent doesn't see.
#
# 6. nsBaseDragSession::InvokeDragSession (widget/nsBaseDragService.cpp)
#    Blocks drag-and-drop text exfiltration from web content. When a user
#    drags selected text out of a web page to another application, Firefox
#    calls InvokeDragSession with the source document. We abort for any
#    non-chrome browsing context. Chrome UI drags (tabs, bookmarks, etc.)
#    are unaffected because their documents have IsChrome() == true.
#
# The user.js prefs dom.allow_cut_copy=false and
# dom.event.clipboardevents.enabled=false are belt-and-suspenders on top
# of this patch. The patch is the authoritative block.

--- a/dom/events/Clipboard.cpp
+++ b/dom/events/Clipboard.cpp
@@ -329,5 +329,8 @@
 already_AddRefed<Promise> Clipboard::ReadHelper(nsIPrincipal& aSubjectPrincipal,
                                                 ReadRequestType aType,
                                                 ErrorResult& aRv) {
+  // ZeroFox: clipboard read access disabled.
+  aRv.ThrowNotAllowedError("ZeroFox policy: clipboard access is disabled.");
+  return nullptr;
   // Create a new promise
   nsGlobalWindowInner* owner = GetOwnerWindow();
@@ -679,5 +682,8 @@
 already_AddRefed<Promise> Clipboard::Write(
     const Sequence<OwningNonNull<ClipboardItem>>& aData,
     nsIPrincipal& aSubjectPrincipal, ErrorResult& aRv) {
+  // ZeroFox: clipboard write access disabled.
+  aRv.ThrowNotAllowedError("ZeroFox policy: clipboard access is disabled.");
+  return nullptr;
   // Create a promise
   RefPtr<nsGlobalWindowInner> owner = GetOwnerWindow();
--- a/dom/base/nsCopySupport.cpp
+++ b/dom/base/nsCopySupport.cpp
@@ -822,6 +822,11 @@
   BrowsingContext* bc = piWindow->GetBrowsingContext();
   const bool chromeShell = bc && bc->IsChrome();

+  // ZeroFox: block clipboard cut/copy for all content including browser UI.
+  if (originalEventMessage == eCopy || originalEventMessage == eCut) {
+    return false;
+  }
+
   // next, fire the cut, copy or paste event
   bool doDefault = true;
   RefPtr<DataTransfer> clipboardData;
--- a/dom/base/Document.cpp
+++ b/dom/base/Document.cpp
@@ -5574,7 +5574,13 @@
   // if they are requesting UI from us, let's fail since we have no UI
   if (aShowUI) {
     return false;
   }

+  // ZeroFox: block clipboard commands from web content.
+  if (aHTMLCommandName.LowerCaseEqualsLiteral("cut") ||
+      aHTMLCommandName.LowerCaseEqualsLiteral("copy") ||
+      aHTMLCommandName.LowerCaseEqualsLiteral("paste")) {
+    return false;
+  }
   //  for optional parameters see dom/src/base/nsHistory.cpp: HistoryImpl::Go()
   //  this might add some ugly JS dependencies?
--- a/widget/nsBaseClipboard.cpp
+++ b/widget/nsBaseClipboard.cpp
@@ -387,8 +387,9 @@
   nsresult rv = NS_ERROR_FAILURE;
   if (aTransferable) {
     mIgnoreEmptyNotification = true;
     // Reject existing pending asyncSetData request if any.
     RejectPendingAsyncSetDataRequestIfAny(aWhichClipboard);
-    rv = SetNativeClipboardData(aTransferable, aWhichClipboard);
+    // ZeroFox: suppress all clipboard writes to the OS clipboard.
+    rv = NS_OK;
     mIgnoreEmptyNotification = false;
   }
--- a/widget/nsBaseDragService.cpp
+++ b/widget/nsBaseDragService.cpp
@@ -322,5 +322,12 @@
   // stash the document of the dom node
   mSourceDocument = aDOMNode->OwnerDoc();
+  // ZeroFox: block drag from web content to prevent text exfiltration.
+  if (mSourceDocument) {
+    mozilla::dom::BrowsingContext* bc = mSourceDocument->GetBrowsingContext();
+    if (bc && !bc->IsChrome()) {
+      return NS_ERROR_ABORT;
+    }
+  }
   mTriggeringPrincipal = aPrincipal;
   mCsp = aCsp;
   mSourceNode = aDOMNode;
