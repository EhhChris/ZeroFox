# PATCH: 006-enforce-vpn
# PURPOSE: Prevent any network connection from being established unless a VPN interface
#          is detected on the host. If VPN is absent, block all connections and show a
#          warning page.
#
# APPROACH OVERVIEW:
#   VPN detection runs on the main process side (not content process).
#   A platform-specific check inspects network interfaces at connection time.
#   If no VPN interface is found, the connection is refused with a custom error page.
#
# ── PART 1: VPN detection module (new file) ───────────────────────────────────
#
# Create: netwerk/base/ZeroFoxVPNCheck.h
# Create: netwerk/base/ZeroFoxVPNCheck.cpp
#
# Interface:
#   namespace zerofox {
#     // Returns true if a VPN interface is active and has an assigned address.
#     // Caches result for up to CACHE_TTL_MS milliseconds to avoid syscall
#     // overhead on every connection.
#     bool IsVPNConnected();
#
#     // Force a fresh check (called on network change events).
#     void InvalidateVPNCache();
#   }
