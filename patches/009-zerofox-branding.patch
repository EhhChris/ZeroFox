# PATCH: 009-zerofox-branding
#
# Creates browser/branding/zerofox/ — a complete custom branding directory
# that replaces Nightly branding when built with:
#   ac_add_options --with-branding=browser/branding/zerofox
#
# TEXT FILES (this patch):
#   configure.sh           — MOZ_APP_DISPLAYNAME and MOZ_MACBUNDLE_ID
#   moz.build              — build directory structure
#   content/moz.build      — registers jar.mn for icon/CSS packaging
#   content/jar.mn         — maps icon PNGs and aboutDialog.css into the jar
#   content/aboutDialog.css — dark theme for about:firefox dialog
#   locales/moz.build      — registers locale jar.mn
#   locales/jar.mn         — registers brand strings (Fluent + .properties)
#   locales/en-US/brand.ftl     — Fluent brand strings
#   locales/en-US/brand.properties — legacy brand strings
#   pref/firefox-branding.js    — branding prefs (no update URLs)
#
# BINARY FILES (handled by build.sh branding step, not patchable):
#   firefox.icns     — macOS app icon; generated by:
#                      iconutil -c icns branding/ZeroFox.iconset -o firefox.icns
#   default16.png    — copied from branding/ZeroFox.iconset/icon_16x16.png
#   default32.png    — copied from branding/ZeroFox.iconset/icon_32x32.png
#   default48.png    — scaled from icon_32x32@2x.png (sips -z 48 48)
#   default64.png    — copied from branding/ZeroFox.iconset/icon_32x32@2x.png
#   default128.png   — copied from branding/ZeroFox.iconset/icon_128x128.png
#   default256.png   — copied from branding/ZeroFox.iconset/icon_256x256.png
#
# NOT INCLUDED (needed for distribution packaging only):
#   disk.icns        — DMG volume icon; add when creating macOS installer
#   document.icns    — file association icon for .html files

--- /dev/null
+++ b/browser/branding/zerofox/configure.sh
@@ -0,0 +1,6 @@
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+MOZ_APP_DISPLAYNAME="ZeroFox"
+MOZ_MACBUNDLE_ID=zerofox
--- /dev/null
+++ b/browser/branding/zerofox/moz.build
@@ -0,0 +1,13 @@
+# -*- Mode: python; indent-tabs-mode: nil; tab-width: 40 -*-
+# vim: set filetype=python:
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+DIRS += ["content", "locales"]
+
+DIST_SUBDIR = "browser"
+export("DIST_SUBDIR")
+
+include("../branding-common.mozbuild")
+FirefoxBranding()
--- /dev/null
+++ b/browser/branding/zerofox/content/moz.build
@@ -0,0 +1,7 @@
+# -*- Mode: python; indent-tabs-mode: nil; tab-width: 40 -*-
+# vim: set filetype=python:
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+JAR_MANIFESTS += ["jar.mn"]
--- /dev/null
+++ b/browser/branding/zerofox/content/jar.mn
@@ -0,0 +1,16 @@
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at https://mozilla.org/MPL/2.0/.
+
+browser.jar:
+% content branding %content/branding/ contentaccessible=yes
+  content/branding/about-logo.png                (../default128.png)
+  content/branding/about-logo@2x.png             (../default256.png)
+  content/branding/about-logo-private.png        (../default128.png)
+  content/branding/about-logo-private@2x.png     (../default256.png)
+  content/branding/icon16.png                    (../default16.png)
+  content/branding/icon32.png                    (../default32.png)
+  content/branding/icon48.png                    (../default48.png)
+  content/branding/icon64.png                    (../default64.png)
+  content/branding/icon128.png                   (../default128.png)
+  content/branding/aboutDialog.css
--- /dev/null
+++ b/browser/branding/zerofox/content/aboutDialog.css
@@ -0,0 +1,19 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at https://mozilla.org/MPL/2.0/. */
+
+#aboutDialogContainer {
+  background-color: #1a1a2e;
+  color: #e0e0e0;
+  color-scheme: dark;
+}
+
+#rightBox {
+  margin-inline: 30px;
+  padding-top: 64px;
+}
+
+#bottomBox {
+  background-color: rgba(0, 0, 0, 0.5);
+  padding: 15px 10px 15px;
+}
--- /dev/null
+++ b/browser/branding/zerofox/locales/moz.build
@@ -0,0 +1,7 @@
+# -*- Mode: python; indent-tabs-mode: nil; tab-width: 40 -*-
+# vim: set filetype=python:
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+JAR_MANIFESTS += ["jar.mn"]
--- /dev/null
+++ b/browser/branding/zerofox/locales/jar.mn
@@ -0,0 +1,12 @@
+#filter substitution
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+[localization] @AB_CD@.jar:
+  branding                                          (en-US/**/*.ftl)
+
+@AB_CD@.jar:
+% locale branding @AB_CD@ %locale/branding/
+# ZeroFox branding only exists in en-US
+  locale/branding/brand.properties (en-US/brand.properties)
--- /dev/null
+++ b/browser/branding/zerofox/locales/en-US/brand.ftl
@@ -0,0 +1,14 @@
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at https://mozilla.org/MPL/2.0/.
+
+## ZeroFox Brand
+
+-brand-shorter-name = ZeroFox
+-brand-short-name = ZeroFox
+-brand-shortcut-name = ZeroFox
+-brand-full-name = ZeroFox
+# This brand name is used when the name must remain constant across versions.
+-brand-product-name = ZeroFox
+-vendor-short-name = ZeroFox
+trademarkInfo = { " " }
--- /dev/null
+++ b/browser/branding/zerofox/locales/en-US/brand.properties
@@ -0,0 +1,7 @@
+# This Source Code Form is subject to the terms of the Mozilla Public
+# License, v. 2.0. If a copy of the MPL was not distributed with this
+# file, You can obtain one at https://mozilla.org/MPL/2.0/.
+
+brandShorterName=ZeroFox
+brandShortName=ZeroFox
+brandFullName=ZeroFox
--- /dev/null
+++ b/browser/branding/zerofox/pref/firefox-branding.js
@@ -0,0 +1,8 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+// ZeroFox branding prefs — no external URLs, no auto-update.
+pref("startup.homepage_override_url", "");
+pref("startup.homepage_welcome_url", "");
+pref("startup.homepage_welcome_url.additional", "");
