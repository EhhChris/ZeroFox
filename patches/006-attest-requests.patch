# PATCH: 006-attest-requests
#
# PURPOSE: Attach a per-request ECIES attestation token to every outbound
#          HTTP(S) request so that a HAProxy (or similar) in front of origin
#          servers can verify that traffic originated from a genuine ZeroFox
#          browser build and reject everything else.
#
# KEY MODEL (private key lives on HAProxy, never in the browser):
#
#   HAProxy holds: ECDSA P-256 private key  (long-lived, rotate on breach)
#   Browser embeds: matching SPKI public key (new one per browser build)
#
#   For each new ZeroFox release:
#     1. Run  scripts/gen-attest-key.sh  to generate a fresh keypair.
#     2. Add the new public key bytes to kHapPublicKeyDer[] and rebuild.
#     3. Deploy the new private key to HAProxy.
#     4. Remove the old public key from HAProxy's allowlist — that build's
#        traffic is now rejected even if the binary is still in circulation.
#
#   The browser binary contains ONLY the public key, which is not secret.
#   Extracting it from the binary gives an attacker nothing useful because
#   you cannot forge an encrypted token without the HAProxy private key to
#   reproduce the ECDH shared secret on the other side.
#
# WHY THIS DOES NOT AFFECT PKI / OAUTH:
#   These headers are an independent application-layer channel added on top
#   of TLS.  TLS handshakes, certificate verification, and all OAuth flows
#   are completely untouched.  HAProxy strips X-ZeroFox-* after verification;
#   downstream servers never see them.
#
# CRYPTOGRAPHIC PROTOCOL (ECIES — Elliptic-Curve Integrated Encryption):
#
#   Per-request browser side:
#     1. Generate a fresh ephemeral EC P-256 keypair (ephem_priv, ephem_pub).
#     2. ECDH(ephem_priv, haproxy_pub) → 32-byte raw shared secret Z.
#     3. ANSI X9.63 KDF: SHA-256(Z || 0x00000001) → take first 16 bytes
#        as an AES-128 key  K_enc.
#     4. Generate random 12-byte IV.
#     5. AES-128-GCM-Encrypt(K_enc, IV, plaintext="zerofox-attest:<ts>:<host>")
#        → ciphertext || 16-byte tag.
#     6. token = base64( ephem_pub(65) || IV(12) || ciphertext_and_tag )
#
#   Headers added:
#     X-ZeroFox-Ts:    Unix timestamp, whole seconds.
#     X-ZeroFox-Token: base64-encoded token (above).
#
#   HAProxy verification (Lua pseudocode — see below for a full sketch):
#     1. Read X-ZeroFox-Ts; reject (403) if |now – ts| > 30 s.
#     2. Decode token from base64.
#     3. Extract ephem_pub (bytes 0–64), IV (bytes 65–76), ct (bytes 77–).
#     4. ECDH(haproxy_priv, ephem_pub) → Z'.
#     5. SHA-256(Z' || 0x00000001)[0:16] → K_enc'.
#     6. AES-128-GCM-Decrypt(K_enc', IV, ct) → plaintext.
#     7. Assert plaintext == "zerofox-attest:" + ts_header + ":" + request_host.
#     8. Forward on success; 403 on failure.
#
# HAPROXY VERIFIER SKETCH (Lua, requires lua-openssl):
#
#   local ssl  = require("openssl")
#   local pkey = require("openssl.pkey")
#   local dgst = require("openssl.digest")
#   local ciph = require("openssl.cipher")
#   local b64  = require("base64")
#
#   local priv = pkey.read(io.open("/etc/haproxy/zerofox-private.pem"):read("*a"), true)
#
#   core.register_action("zerofox_attest", {"http-req"}, function(txn)
#     local ts  = txn.http:req_get_headers()["x-zerofox-ts"][0]
#     local tok = txn.http:req_get_headers()["x-zerofox-token"][0]
#     if not ts or not tok then txn:set_var("req.attest_ok", false); return end
#
#     if math.abs(os.time() - tonumber(ts)) > 30 then
#       txn:set_var("req.attest_ok", false); return
#     end
#
#     local raw      = b64.decode(tok)
#     local ephem_pt = raw:sub(1, 65)       -- 0x04 || x(32) || y(32)
#     local iv       = raw:sub(66, 77)      -- 12-byte GCM nonce
#     local ct       = raw:sub(78)          -- ciphertext + 16-byte GCM tag
#
#     -- Reconstruct ephemeral public key as an EC point on prime256v1.
#     local ephem_pub = pkey.new({type="EC", curve="prime256v1"})
#     ephem_pub:set_key_point(ephem_pt)     -- set raw 04||x||y point
#
#     -- ECDH: Z = raw shared secret (32 bytes).
#     local Z = priv:derive(ephem_pub)
#
#     -- ANSI X9.63 KDF: K_enc = SHA-256(Z || 0x00000001)[0:16]
#     local h = dgst.new("sha256")
#     h:update(Z); h:update("\x00\x00\x00\x01")
#     local K_enc = h:final():sub(1, 16)
#
#     -- AES-128-GCM decrypt (tag is last 16 bytes of ct).
#     local tag    = ct:sub(-16)
#     local body   = ct:sub(1, -17)
#     local c = ciph.new("aes-128-gcm")
#     c:decrypt(K_enc, iv); c:setTag(tag)
#     local plain = c:update(body) .. c:final()
#
#     -- Verify canonical message.
#     local host     = txn.sf:req_hdr("host")
#     local expected = "zerofox-attest:" .. ts .. ":" .. host
#     txn:set_var("req.attest_ok", plain == expected)
#   end)
#
#   # In the frontend block:
#   #   http-request lua.zerofox_attest
#   #   http-request deny if !{ var(req.attest_ok) -m bool }
#   #   http-request del-header X-ZeroFox-Ts
#   #   http-request del-header X-ZeroFox-Token
#
# KEY MANAGEMENT:
#   See  scripts/gen-attest-key.sh  for keypair generation.
#   The script prints the public key bytes for kHapPublicKeyDer[] and the
#   private key PEM to deploy to HAProxy.
#
#   To invalidate a build: remove its public key from HAProxy (or rotate the
#   HAProxy private key and issue a new browser build with the new public key).
#
# FILES ADDED:
#   netwerk/base/ZeroFoxAttest.h
#   netwerk/base/ZeroFoxAttest.cpp
#
# FILES MODIFIED:
#   netwerk/protocol/http/nsHttpChannel.cpp
#       — include ZeroFoxAttest.h, call zerofox::AddAttestHeaders() at
#         end of SetupChannelForTransaction() before return NS_OK.
#   netwerk/base/moz.build
#       — add ZeroFoxAttest.cpp to UNIFIED_SOURCES.

