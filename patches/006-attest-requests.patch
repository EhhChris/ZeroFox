@@ -0,0 +1,44 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at https://mozilla.org/MPL/2.0/. */
+
+#ifndef ZeroFoxAttest_h__
+#define ZeroFoxAttest_h__
+
+#include "nsHttpRequestHead.h"
+#include "nsIURI.h"
+#include "nsresult.h"
+
+namespace zerofox {
+
+/**
+ * AddAttestHeaders — inject X-ZeroFox-Ts and X-ZeroFox-Token into aHead.
+ *
+ * Called from nsHttpChannel::SetupChannelForTransaction() for every outbound
+ * HTTP/HTTPS request.  The token is an ECIES-encrypted payload that can only
+ * be decrypted by the HAProxy that holds the matching private key, proving
+ * the request originated from a genuine ZeroFox browser build.
+ *
+ * Protocol:  ECIES with EC P-256, ANSI X9.63 KDF (SHA-256), AES-128-GCM.
+ *
+ * Key model:
+ *   - HAProxy holds the EC P-256 private key (never leaves the gateway).
+ *   - Each ZeroFox build embeds only the matching SPKI public key.
+ *   - A new keypair per browser release lets HAProxy invalidate old builds
+ *     by rotating its private key or removing the old public key from its
+ *     allowlist.
+ *
+ * Behaviour when not configured:
+ *   If the embedded public key is the all-zeros placeholder, this function
+ *   is a silent no-op.  No request is ever blocked by this code.
+ *
+ * Thread-safety:
+ *   The public key is imported from DER at most once per process and cached.
+ *   Safe to call from any thread that can already call nsHttpChannel methods.
+ */
+nsresult AddAttestHeaders(mozilla::net::nsHttpRequestHead& aHead,
+                          nsIURI* aURI);
+
+}  // namespace zerofox
+
+#endif  // ZeroFoxAttest_h__

diff --git a/netwerk/base/ZeroFoxAttest.cpp b/netwerk/base/ZeroFoxAttest.cpp
new file mode 100644
--- /dev/null
+++ b/netwerk/base/ZeroFoxAttest.cpp
@@ -0,0 +1,232 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at https://mozilla.org/MPL/2.0/. */
+
+// ZeroFox per-request ECIES attestation header injector.
+//
+// Adds two HTTP headers to every outbound HTTP/HTTPS request:
+//
+//   X-ZeroFox-Ts:    current Unix timestamp (seconds, decimal string).
+//   X-ZeroFox-Token: base64( ephem_pub(65) || IV(12) || AES-128-GCM-ct )
+//
+// The ciphertext decrypts to "zerofox-attest:<ts>:<ascii_host>" when
+// HAProxy performs ECDH with its private key and the ephemeral public key.
+//
+// The HAProxy private key (kHapPublicKeyDer's counterpart) never appears
+// in this file or the browser binary.  Only the public key is embedded.
+// See the patch header comment and scripts/gen-attest-key.sh for setup.
+
+#include "ZeroFoxAttest.h"
+
+#include "keyhi.h"
+#include "mozilla/Base64.h"
+#include "mozilla/Logging.h"
+#include "mozilla/StaticMutex.h"
+#include "mozilla/UniquePtr.h"
+#include "mozilla/Unused.h"
+#include "nsHttp.h"
+#include "nsHttpRequestHead.h"
+#include "nsIURI.h"
+#include "nsString.h"
+#include "pk11pub.h"
+#include "prtime.h"
+#include "ScopedNSSTypes.h"
+#include "secasn1.h"
+#include "secitem.h"
+
+namespace zerofox {
+
+static mozilla::LazyLogModule sLog("ZeroFoxAttest");
+
+// ── HAProxy public key ────────────────────────────────────────────────────────
+//
+// SubjectPublicKeyInfo DER-encoded EC P-256 public key from HAProxy.
+//
+// PLACEHOLDER: all bytes 0x00.  Attestation is DISABLED until replaced.
+//
+// To generate a keypair and update this array:
+//   scripts/gen-attest-key.sh
+//
+// The matching private key goes to HAProxy — it never belongs in this file.
+//
+// A valid EC P-256 SPKI DER blob is 91 bytes and starts with 0x30.
+// The placeholder (all zeros) is detected at startup and skipped silently.
+
+// clang-format off
+static const uint8_t kHapPublicKeyDer[] = {
+  // ── REPLACE: paste  xxd -i haproxy-public.der  output here ──────────────
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
+  0x00,
+  // ── END REPLACE ───────────────────────────────────────────────────────────
+};
+// clang-format on
+
+static constexpr uint32_t kHapPublicKeyDerLen =
+    static_cast<uint32_t>(sizeof(kHapPublicKeyDer));
+
+// Valid P-256 SPKI DER starts with 0x30 (ASN.1 SEQUENCE).
+// An all-zero buffer is the placeholder; treat as "not configured".
+static bool KeyIsPlaceholder() { return kHapPublicKeyDer[0] != 0x30; }
+
+// ── P-256 curve params for ephemeral keygen ───────────────────────────────────
+// DER encoding of OID prime256v1 (1.2.840.10045.3.1.7):
+//   06 08 2a 86 48 ce 3d 03 01 07
+static const uint8_t kP256OidDer[] = {
+    0x06, 0x08, 0x2a, 0x86, 0x48, 0xce, 0x3d, 0x03, 0x01, 0x07};
+
+// ── Cached HAProxy public key ─────────────────────────────────────────────────
+
+static mozilla::StaticMutex sKeyMutex;
+static SECKEYPublicKey* sHapPubKey = nullptr;  // process-lifetime; not freed
+static bool sKeyLoaded = false;
+
+// Returns HAProxy's public key, importing and caching it on first call.
+// Returns nullptr if the key is the placeholder or import fails.
+static SECKEYPublicKey* GetHapPublicKey() {
+  mozilla::StaticMutexAutoLock lock(sKeyMutex);
+  if (sKeyLoaded) return sHapPubKey;
+  sKeyLoaded = true;
+
+  if (KeyIsPlaceholder()) {
+    MOZ_LOG(sLog, mozilla::LogLevel::Warning,
+            ("ZeroFoxAttest: public key is the all-zeros placeholder — "
+             "request attestation is DISABLED.  Run "
+             "scripts/gen-attest-key.sh, replace kHapPublicKeyDer[] in "
+             "netwerk/base/ZeroFoxAttest.cpp, and rebuild."));
+    return nullptr;
+  }
+
+  SECItem spkiItem = {siBuffer, const_cast<uint8_t*>(kHapPublicKeyDer),
+                      kHapPublicKeyDerLen};
+
+  UniqueCERTSubjectPublicKeyInfo spki(
+      SECKEY_DecodeDERSubjectPublicKeyInfo(&spkiItem));
+  if (!spki) {
+    MOZ_LOG(sLog, mozilla::LogLevel::Error,
+            ("ZeroFoxAttest: SECKEY_DecodeDERSubjectPublicKeyInfo failed "
+             "(bad DER bytes?)."));
+    return nullptr;
+  }
+
+  SECKEYPublicKey* key = SECKEY_ExtractPublicKey(spki.get());
+  if (!key) {
+    MOZ_LOG(sLog, mozilla::LogLevel::Error,
+            ("ZeroFoxAttest: SECKEY_ExtractPublicKey failed."));
+    return nullptr;
+  }
+
+  sHapPubKey = key;
+  return key;
+}
+
+// ── Public API ────────────────────────────────────────────────────────────────
+
+nsresult AddAttestHeaders(mozilla::net::nsHttpRequestHead& aHead,
+                          nsIURI* aURI) {
+  MOZ_ASSERT(aURI);
+
+  SECKEYPublicKey* hapPubKey = GetHapPublicKey();
+  if (!hapPubKey) {
+    return NS_OK;  // Placeholder or load failure — skip silently.
+  }
+
+  // ── 1. Timestamp ─────────────────────────────────────────────────────────
+  int64_t ts = static_cast<int64_t>(PR_Now() / PR_USEC_PER_SEC);
+  nsAutoCString tsStr;
+  tsStr.AppendInt(ts);
+
+  // ── 2. Host ───────────────────────────────────────────────────────────────
+  // Non-HTTP resources (about:, data:, blob:, …) have no host; skip them.
+  nsAutoCString host;
+  if (NS_FAILED(aURI->GetAsciiHost(host)) || host.IsEmpty()) {
+    return NS_OK;
+  }
+
+  // ── 3. Canonical plaintext ────────────────────────────────────────────────
+  nsAutoCString plaintext("zerofox-attest:");
+  plaintext.Append(tsStr);
+  plaintext.Append(':');
+  plaintext.Append(host);
+
+  // ── 4. Ephemeral EC P-256 keypair ─────────────────────────────────────────
+  // Generated fresh per-request; the public half is included in the token so
+  // HAProxy can replicate the ECDH shared secret.
+  UniquePK11SlotInfo slot(PK11_GetInternalSlot());
+  if (!slot) {
+    MOZ_LOG(sLog, mozilla::LogLevel::Error,
+            ("ZeroFoxAttest: PK11_GetInternalSlot failed."));
+    return NS_OK;
+  }
+
+  SECItem curveParams = {siBuffer, const_cast<uint8_t*>(kP256OidDer),
+                         static_cast<unsigned int>(sizeof(kP256OidDer))};
+  SECKEYPublicKey* ephemPubRaw = nullptr;
+  UniqueSECKEYPrivateKey ephemPriv(
+      PK11_GenerateKeyPair(slot.get(), CKM_EC_KEY_PAIR_GEN, &curveParams,
+                           &ephemPubRaw, PR_FALSE, PR_FALSE, nullptr));
+  UniqueSECKEYPublicKey ephemPub(ephemPubRaw);
+
+  if (!ephemPriv || !ephemPub) {
+    MOZ_LOG(sLog, mozilla::LogLevel::Error,
+            ("ZeroFoxAttest: PK11_GenerateKeyPair failed."));
+    return NS_OK;
+  }
+
+  // ── 5. ECDH + ANSI X9.63 KDF → 128-bit AES key ───────────────────────────
+  // PK11_PubDeriveWithKDF performs ECDH(ephemPriv, hapPubKey) then applies
+  // the ANSI X9.63 KDF (SHA-256(Z || 0x00000001)) to produce a 16-byte
+  // AES-128-GCM key.  HAProxy replicates this with its private key and the
+  // ephemeral public key from the token.
+  UniquePK11SymKey aesKey(PK11_PubDeriveWithKDF(
+      ephemPriv.get(), hapPubKey,
+      PR_FALSE,        // isSender (value ignored for CKM_ECDH1_DERIVE)
+      nullptr,         // randomA
+      nullptr,         // randomB
+      CKM_ECDH1_DERIVE,
+      CKM_AES_128_GCM,
+      CKA_ENCRYPT,
+      16,              // 128-bit key
+      CKD_SHA256_KDF,  // ANSI X9.63 with SHA-256
+      nullptr,         // sharedData (none)
+      nullptr));       // wincx
+
+  if (!aesKey) {
+    MOZ_LOG(sLog, mozilla::LogLevel::Error,
+            ("ZeroFoxAttest: ECDH/KDF failed."));
+    return NS_OK;
+  }
+
+  // ── 6. Random 12-byte GCM nonce ───────────────────────────────────────────
+  uint8_t iv[12];
+  if (PK11_GenerateRandom(iv, sizeof(iv)) != SECSuccess) {
+    MOZ_LOG(sLog, mozilla::LogLevel::Error,
+            ("ZeroFoxAttest: PK11_GenerateRandom failed."));
+    return NS_OK;
+  }
+
+  // ── 7. AES-128-GCM encrypt ────────────────────────────────────────────────
+  // Output: ciphertext || 16-byte GCM tag (PK11_Encrypt appends the tag).
+  CK_GCM_PARAMS gcmParams;
+  gcmParams.pIv      = iv;
+  gcmParams.ulIvLen  = sizeof(iv);
+  gcmParams.ulIvBits = 96;
+  gcmParams.pAAD     = nullptr;
+  gcmParams.ulAADLen = 0;
+  gcmParams.ulTagBits = 128;
+
+  SECItem gcmParamItem = {siBuffer,
+                          reinterpret_cast<uint8_t*>(&gcmParams),
+                          sizeof(gcmParams)};
+
+  uint32_t ptLen = static_cast<uint32_t>(plaintext.Length());
+  uint32_t ctBufLen = ptLen + 16;  // plaintext + 16-byte GCM tag
+  mozilla::UniquePtr<uint8_t[]> ctBuf(new uint8_t[ctBufLen]);
+  uint32_t ctLen = 0;
+
+  SECStatus rv = PK11_Encrypt(
+      aesKey.get(), CKM_AES_GCM, &gcmParamItem,
+      ctBuf.get(), &ctLen, ctBufLen,
+      reinterpret_cast<const uint8_t*>(plaintext.get()), ptLen);
+
+  if (rv != SECSuccess) {
+    MOZ_LOG(sLog, mozilla::LogLevel::Error,
+            ("ZeroFoxAttest: AES-128-GCM encrypt failed."));
+    return NS_OK;  // Never block the request over attestation.
+  }
+
+  // ── 8. Assemble token: ephem_pub(65) || IV(12) || ciphertext_and_tag ──────
+  // ephemPub->u.ec.publicValue holds the uncompressed point 04 || x || y.
+  const SECItem& pubPt = ephemPub->u.ec.publicValue;  // 65 bytes for P-256
+  uint32_t tokenLen = pubPt.len + sizeof(iv) + ctLen;
+  mozilla::UniquePtr<uint8_t[]> tokenBuf(new uint8_t[tokenLen]);
+  uint8_t* p = tokenBuf.get();
+  memcpy(p, pubPt.data, pubPt.len);  p += pubPt.len;
+  memcpy(p, iv, sizeof(iv));         p += sizeof(iv);
+  memcpy(p, ctBuf.get(), ctLen);
+
+  // ── 9. Base64-encode and inject headers ───────────────────────────────────
+  nsAutoCString tokenB64;
+  nsresult nsrv = mozilla::Base64Encode(
+      reinterpret_cast<const char*>(tokenBuf.get()), tokenLen, tokenB64);
+  if (NS_FAILED(nsrv)) {
+    return NS_OK;
+  }
+
+  mozilla::Unused << aHead.SetHeader("X-ZeroFox-Ts"_ns, tsStr, false);
+  mozilla::Unused << aHead.SetHeader("X-ZeroFox-Token"_ns, tokenB64, false);
+
+  return NS_OK;
+}
+
+}  // namespace zerofox

diff --git a/netwerk/protocol/http/nsHttpChannel.cpp b/netwerk/protocol/http/nsHttpChannel.cpp
