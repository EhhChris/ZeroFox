+#include "ZeroFoxAttest.h"
 #include <inttypes.h>

 #include "mozilla/ScopeExit.h"
@@ -1787,6 +1788,10 @@ nsresult nsHttpChannel::SetupChannelForTransaction() {
   if (mWebTransportSessionEventListener) {
     mCaps |= NS_HTTP_STICKY_CONNECTION;
