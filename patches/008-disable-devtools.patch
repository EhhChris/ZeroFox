# PATCH: 008-disable-devtools
#
# Disables all developer tools unconditionally.
#
# The DisableDeveloperTools enterprise policy (in policies.json) already
# gates devtools through the devtools.policy.disabled pref, which covers:
#   - F12 / Ctrl+Shift+I keyboard shortcuts (DevToolsStartup.onWindowReady skips hookWindow)
#   - All Tools > Web Developer menu items (hidden by devtools-browser.js)
#   - Right-click Inspect (removed when pref is set)
#   - about:debugging, about:devtools-toolbox, about:profiling (blocked)
#   - --start-debugger-server and --jsconsole command-line flags
#   - Remote debugging server
#
# This patch hardens further by replacing the pref-based runtime check in both
# shim entry points with an unconditional `return true`. This means DevTools
# remain disabled even if someone modifies the pref at runtime (e.g. via
# external tooling or a compromised about:config bypass).
#
# Two files are patched because two independent shim modules both expose
# isDisabledByPolicy() and are each called from different code paths:
#   - DevToolsShim gates lazy devtools initialization and extension APIs
#   - DevToolsStartup gates window hookup, keyboard shortcuts, and CLI flags

--- a/devtools/startup/DevToolsShim.sys.mjs
+++ b/devtools/startup/DevToolsShim.sys.mjs
@@ -62,6 +62,6 @@
    * Returns true if the devtools are completely disabled and can not be enabled. All
    * entry points should return without throwing, initDevTools should never be called.
    */
   isDisabledByPolicy() {
-    return Services.prefs.getBoolPref(DEVTOOLS_POLICY_DISABLED_PREF, false);
+    return true; // ZeroFox: developer tools permanently disabled.
   },
--- a/devtools/startup/DevToolsStartup.sys.mjs
+++ b/devtools/startup/DevToolsStartup.sys.mjs
@@ -348,3 +348,3 @@
   isDisabledByPolicy() {
-    return Services.prefs.getBoolPref(DEVTOOLS_POLICY_DISABLED_PREF, false);
+    return true; // ZeroFox: developer tools permanently disabled.
   },
@@ -683,6 +683,9 @@
   },

   onMoreToolsViewShowing(moreToolsView) {
+    if (this.isDisabledByPolicy()) {
+      return; // ZeroFox: developer tools permanently disabled.
+    }
     this.addDevToolsItemsToSubview(moreToolsView);
   },

