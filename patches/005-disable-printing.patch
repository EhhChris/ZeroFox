# PATCH: 005-disable-printing
#
# Blocks all print paths unconditionally. Three enforcement layers:
#
# 1. DisablePrinting enterprise policy (policies.json)
#    Removes the print menu item, toolbar button, and Ctrl+P/Cmd+P shortcut.
#    DOES NOT block window.print() or internal print-to-PDF calls from JS.
#
# 2. user.js: print.enabled = false
#    PrintOuter() (the window.print() entry point) checks StaticPrefs::print_enabled()
#    and silently returns when false. This blocks JS-triggered print dialogs.
#    See: dom/base/nsGlobalWindowOuter.cpp::PrintOuter
#
# 3. nsPrintJob::CommonPrint (this patch)
#    The single funnel point for all print and print-preview operations, regardless
#    of trigger source. Both nsPrintJob::Print and nsPrintJob::PrintPreview call
#    CommonPrint, so one block here covers:
#      - Programmatic print calls that bypass PrintOuter
#      - Print-to-PDF (which uses the same print pipeline)
#      - Any extension or internal caller that reaches nsPrintJob directly
#    Returns NS_ERROR_ABORT, which the caller uses to call FirePrintingErrorEvent
#    and DestroyPrintingData — a clean shutdown path.

--- a/layout/printing/nsPrintJob.cpp
+++ b/layout/printing/nsPrintJob.cpp
@@ -326,6 +326,8 @@
 nsresult nsPrintJob::CommonPrint(bool aIsPrintPreview,
                                  nsIPrintSettings* aPrintSettings,
                                  nsIWebProgressListener* aWebProgressListener,
                                  Document& aSourceDoc) {
+  // ZeroFox: printing permanently disabled.
+  return NS_ERROR_ABORT;
   // Callers must hold a strong reference to |this| to ensure that we stay
   // alive for the duration of this method, because our main owning reference
